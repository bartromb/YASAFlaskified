# YASAFlaskified — environment variables
# Copy to `.env` and fill in. Loaded by docker-compose.yml (env_file).
#
# Application secrets and runtime configuration live in
# /data/slaapkliniek/instance/config.json (see config.json.example).
# This .env is for Docker Compose interpolation and container-level
# overrides only — it does not contain SECRET_KEY or passwords.

# Docker image tag (must match the version built locally; see version.py)
APP_VERSION=0.8.37

# Optional overrides — env vars take precedence over config.json values.
# Uncomment to override.
# YASAFLASKIFIED_REDIS_HOST=redis
# YASAFLASKIFIED_REDIS_PORT=6379
# YASAFLASKIFIED_LOG_LEVEL=INFO
# YASAFLASKIFIED_UPLOAD_FOLDER=/data/slaapkliniek/uploads
# YASAFLASKIFIED_PROCESSED_FOLDER=/data/slaapkliniek/processed
# YASAFLASKIFIED_SQLALCHEMY_DATABASE_URI=sqlite:////data/slaapkliniek/instance/users.db

# Matplotlib needs a writable cache dir inside the container
MPLCONFIGDIR=/tmp/mplconfig
